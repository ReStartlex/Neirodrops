# ── neurodrop.ru — переменные окружения ──────────────────────────────
# Базовый URL FastAPI-бэкенда (публичный API каталога). На VPS бэкенд
# слушает только localhost, и Next.js ходит к нему server-side.
NEURODROP_API_BASE=http://127.0.0.1:8080

# Канонический адрес сайта (для метатегов, sitemap, OG).
NEXT_PUBLIC_SITE_URL=https://neurodrop.ru

# Ссылка на покупательский Telegram-бот (кнопки «Купить» / «Войти»
# пока ведут в бот, где покупка уже работает; на сайте оплату
# подключим после одобрения ЮMoney).
NEXT_PUBLIC_SHOP_BOT_URL=https://t.me/neirodropi_bot

# Порт, на котором поднимается next start (pm2). farmcore занимает 3000.
PORT=3001

# ── OAuth для мульти-входа (Google / Яндекс) ─────────────────────────
# Заполнять реальными значениями в /opt/neurodrop/.env на VPS.
# Redirect URI:
#   Google → https://neurodrop.ru/api/auth/google/callback
#   Яндекс → https://neurodrop.ru/api/auth/yandex/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
# Необязательный общий секрет с бэкендом (доп. защита server-to-server
# вызова /api/site/auth/oauth). Если задан здесь — задай ТО ЖЕ значение
# в /opt/funpay-ns-bot/.env как INTERNAL_AUTH_SECRET.
INTERNAL_AUTH_SECRET=
